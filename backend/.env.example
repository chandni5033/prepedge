# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/interviewforge

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=replace_with_a_long_random_string

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Groq API key for AI-generated interview questions/feedback (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key

# Frontend URL, used for CORS and OAuth redirect
CLIENT_URL=http://localhost:5173

# Server port
PORT=5000

# development | production | test
NODE_ENV=development